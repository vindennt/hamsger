{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "docs",
    "scripts/combined/run.ts",
    "scripts/double_ratchet/run.ts",
    "scripts/hamsger_cli/run.ts"
  ]
}
